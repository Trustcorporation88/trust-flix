# Painel web
PORT=80
NODE_ENV=production
PANEL_USERNAME=admin
PANEL_PASSWORD=troque-esta-senha
SESSION_SECRET=gere-uma-chave-longa-e-unica
APP_SECRET=gere-outra-chave-longa-para-criptografar-tokens

# Bot
BOT_CLIENT_ID=sua-marca-bot
TIMEZONE=America/Sao_Paulo
IGNORE_GROUP_MESSAGES=true

# Opcional: também podem ser configurados pelo painel
GROQ_API_KEY=
MERCADOPAGO_ACCESS_TOKEN=
PUSHINPAY_API_TOKEN=
PIX_KEY=
EVOLUTION_API_KEY=
LEAD_IMPORT_TOKEN=
OUTBOUND_WEBHOOK_SECRET=

# URL pública e webhooks seguros
PUBLIC_BASE_URL=
WEBHOOK_SECRET=gere-uma-chave-exclusiva-para-webhooks
ALLOW_UNSIGNED_WEBHOOKS=false
