# SocialFlow Site — variáveis de ambiente

# API
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_JETBOT_API=
NEXT_PUBLIC_SITE_URL=https://www.socialflow.site

# Auth (obrigatório em produção)
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio
ADMIN_EMAIL=admin@socialflow.site
ADMIN_PASSWORD=troque-esta-senha-forte
ADMIN_NAME=Admin SocialFlow

# Cadastro público (em produção fica OFF por padrão)
ALLOW_REGISTER=false

# Postiz
POSTIZ_API_URL=
POSTIZ_API_KEY=

# Content Studio AI (server-side)
CONTENT_STUDIO_AI_PROVIDER=deepseek
CONTENT_STUDIO_AI_API_KEY=
CONTENT_STUDIO_AI_MODEL=deepseek-chat

# Pagamentos (opcional)
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
MERCADO_PAGO_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=

# Analytics (opcional)
NEXT_PUBLIC_GA_ID=

NODE_ENV=development
